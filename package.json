{
	"name": "spendr",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "expo start --dev-client --port 8083",
		"reset-project": "node ./scripts/reset-project.js",
		"android": "expo run:android",
		"android:start": "expo start --dev-client --android --port 8083",
		"ios": "expo run:ios",
		"ios:start": "expo start --dev-client --ios --port 8083",
		"web": "expo start --web --port 8083",
		"test": "jest",
		"test:watch": "jest --watchAll",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"build:android": "expo prebuild --platform android --clean && cd android && ./gradlew bundleRelease",
		"build:apk": "expo prebuild --platform android --clean && cd android && ./gradlew assembleRelease",
		"build:dev:apk": "APP_ENV=development expo prebuild --platform android --clean && cd android && ./gradlew assembleDebug",
		"eas:build:apk": "eas build --platform android --profile preview",
		"eas:build:dev": "eas build --platform android --profile development",
		"update:preview": "eas update --branch preview",
		"update:prod": "eas update --branch production"
	},
	"jest": {
		"preset": "jest-expo"
	},
	"dependencies": {
		"@expo/vector-icons": "^15.0.2",
		"@react-native-async-storage/async-storage": "2.2.0",
		"@react-navigation/bottom-tabs": "^7.2.0",
		"@react-navigation/native": "^7.0.14",
		"@react-navigation/stack": "^7.8.9",
		"expo": "^55",
		"expo-blur": "~55.0.12",
		"expo-constants": "~55.0.11",
		"expo-dev-client": "^55.0.22",
		"expo-device": "~55.0.12",
		"expo-document-picker": "~55.0.11",
		"expo-file-system": "~55.0.14",
		"expo-font": "~55.0.6",
		"expo-haptics": "~55.0.11",
		"expo-linking": "~55.0.11",
		"expo-local-authentication": "~55.0.11",
		"expo-localization": "^55.0.11",
		"expo-notifications": "~55.0.16",
		"expo-router": "~55.0.10",
		"expo-secure-store": "^57.0.1",
		"expo-sharing": "~55.0.16",
		"expo-splash-screen": "~55.0.15",
		"expo-sqlite": "~55.0.13",
		"expo-status-bar": "~55.0.5",
		"expo-symbols": "~55.0.7",
		"expo-system-ui": "~55.0.13",
		"expo-updates": "~55.0.26",
		"expo-web-browser": "~55.0.12",
		"i18next": "^26.0.3",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"react-i18next": "^17.0.2",
		"react-native": "0.83.4",
		"react-native-chart-kit": "^6.12.0",
		"react-native-gesture-handler": "~2.30.0",
		"react-native-get-random-values": "^2.0.0",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0",
		"react-native-svg": "15.15.3",
		"react-native-web": "^0.21.0",
		"react-native-webview": "13.16.0",
		"react-native-worklets": "~0.7.0"
	},
	"devDependencies": {
		"@babel/core": "^7.25.2",
		"@biomejs/biome": "^2.4.10",
		"@types/jest": "^29.5.12",
		"@types/react": "~19.2.10",
		"@types/react-test-renderer": "^18.3.0",
		"dotenv": "^17.4.1",
		"jest": "^29.2.1",
		"jest-expo": "~55.0.13",
		"react-test-renderer": "19.2.0",
		"typescript": "~5.9.2"
	},
	"private": true
}