# Copie para .env e preencha. O .env real nunca vai para o git.

# Em desenvolvimento aponta para o Postgres do docker-compose (porta 15432).
# Dentro do compose de produção o host é `postgres`, não 127.0.0.1.
DATABASE_URL=postgresql://spendr_user:spendr_password@127.0.0.1:15432/spendr_db?schema=public

PORT=3009
NODE_ENV=development

# Obrigatório: assina os access tokens. A API se recusa a subir sem ele.
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Access token curto; a sessão longa vive no refresh token, que é rotacionado a cada uso.
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=30

# Teto de linhas por página de sync, nas duas direções.
SYNC_PAGE_SIZE=500

# Vazio = qualquer origem, que é o correto para um app nativo (não há navegador nem
# header Origin). Preencher só quando existir um front web.
CORS_ORIGINS=

# Credenciais do Postgres do docker-compose.
POSTGRES_USER=spendr_user
POSTGRES_PASSWORD=spendr_password
POSTGRES_DB=spendr_db
