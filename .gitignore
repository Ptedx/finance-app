# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native folders (should be generated by expo prebuild)
android/
ios/

# Expo prebuild output (native dirs are tracked for bare workflow,
# but generated build artifacts are not)
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/.idea/
android/app/release/
ios/build/
ios/Pods/
ios/DerivedData/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/

# Signing keys — never commit these
*.jks
*.keystore
*.p8
*.p12
*.mobileprovision
*.pem
# Exception: debug.keystore is auto-generated and safe to track
!android/app/debug.keystore

# Metro
.metro-health-check*

# Package managers — only bun.lock is used
package-lock.json
yarn.lock

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
.fuse*

# Environment / secrets
.env
.env*.local
plan-*.md

# TypeScript
*.tsbuildinfo

# Misc project-specific
app-example
.deletelater
submission
Dockerfile
build.sh

# Build outputs
*.apk
*.aab
